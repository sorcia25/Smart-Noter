{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Smart Noter",
  "version": "1.2.2",
  "identifier": "com.smartnoter.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "beforeBundleCommand": "node scripts/stage-dlls.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Smart Noter",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "center": true,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "windowEffects": {
          "effects": ["mica"]
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; media-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/audio/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
    "resources": { "bundle-dlls/*": "./" }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY0QTY5MjMxRDk2QUZDMEEKUldRSy9HclpNWkttWk9wcVViM1FzUFpTblRsNC9BK1JMS1ozZmNXV1NJbmdQU2xVdDdORS9wVlIK",
      "endpoints": ["https://github.com/sorcia25/Smart-Noter/releases/latest/download/latest.json"],
      "windows": { "installMode": "passive" }
    }
  }
}
