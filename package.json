{
  "name": "smart-noter",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "lint": "biome check .",
    "lint:fix": "biome check --apply .",
    "format": "biome format --write .",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "extract-mocks": "node scripts/extract-mocks.mjs",
    "generate:i18n-keys": "node scripts/generate-i18n-keys.mjs",
    "generate:bindings": "cd src-tauri && cargo run --bin specta-export",
    "check:hardcoded-strings": "node scripts/check-no-hardcoded-strings.mjs",
    "check:stories": "node scripts/check-stories-coverage.mjs",
    "check:node-types": "tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.3.0",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-log": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "date-fns": "^4.1.0",
    "i18next": "^23.16.0",
    "i18next-icu": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-i18next": "^15.1.0",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.27.0",
    "sonner": "^1.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@playwright/test": "^1.48.0",
    "@storybook/addon-essentials": "^8.3.0",
    "@storybook/react": "^8.3.0",
    "@storybook/react-vite": "^8.3.0",
    "@tauri-apps/cli": "^2.1.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "jsdom": "^25.0.0",
    "lefthook": "^1.7.0",
    "msw": "^2.4.0",
    "storybook": "^8.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  }
}
